COPYRIGHT="Leibniz Institute DSMZ-German Collection of Microorganisms and Cell Cultures GmbH"

PYV=3.13
UV_CACHE_DIR=.uv/cache
UV_INSTALL_DIR=.uv/bin
UV_PYTHON_BIN_DIR=.uv/python/bin
UV_TOOL_DIR=.uv/tools
UV_TOOL_BIN_DIR=.uv/tools/bin
UV_NO_MODIFY_PATH=1
UV_LINK_MODE=copy
UV_PYTHON_INSTALL_DIR=.uv/python

PNPM_HOME=.pnpm
PNPM_BIN=.pnpm/bin

UV_VERSION=0.11.26
PNPM_VERSION=11.10.0

CONFIG_SHELL=configs/lint/shellcheckrc
CONFIG_DOCS=.zensical.toml

BIN_RUN_ENV_LINT=bin/lint/lint_env.sh
BIN_RUN_LICENSE_LINT=bin/lint/licenses.sh
BIN_RUN_LFS_LINT=bin/lint/lfs_files.sh
BIN_INSTALL_UV=bin/install/uv.sh
BIN_INSTALL_PNMP=bin/install/pnpm.sh

PKG=packages
PKG_DOCS=packages/strain_discovery_docs

SDD_ENV=packages/strain_discovery_dataset/.env
DOCS_ENV=packages/strain_discovery_docs/.env

# Configuration which are required for docker compose and should be copied to ROOT/.env

BIN_DEPLOY_PREP=bin/deploy/prep.sh
BIN_DEPLOY_REQ=bin/deploy/req.sh

BIN_DEPLOY_HEALTH=bin/deploy/health.sh
BIN_DEPLOY_ENTRY_DEV=bin/deploy/entry_dev.sh
BIN_DEPLOY_ENTRY_PROD=bin/deploy/entry_prod.sh
BIN_EVALUATE_LOG=bin/evaluate/count_validation_errors.sh

DOC_PORT=9196

# Passwords should be passed as secrets

MONGO_SDD_PASSWORD=password2
LPSN_PASSWORD=password3

# Main server configuration

MONGO_HOST=mongo
MONGO_PORT=27372
MONGO_SOCKET=/mongo/mongodb-27372.sock

MONGO_SDD_USER=strain_discovery_user
MONGO_SDD_DATABASE=strain_discovery_database
MONGO_SDD_COLLECTION=strain_discovery_dataset

LPSN_USER=user@mail.local

# Whether the database should be created or not

SDD_UPDATE=true
